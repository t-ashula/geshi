{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@geshi/logger": ["packages/logger/src"],
      "@geshi/crawler": ["packages/crawler/src"],
      "@geshi/scribe": ["packages/scribe-client/src"],
      "@geshi/model": ["packages/model/src"],
      "@geshi/ui": ["packages/ui/src/*"]
    }
  }
}
