{
  "name": "geshi",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "backend:dev": "tsx watch backend/src/index.ts",
    "backend:start": "node --import tsx backend/src/index.ts",
    "worker:start": "sh backend/scripts/start-workers.sh",
    "worker:acquire-content": "node --import tsx backend/src/workers/acquire-content/main.ts",
    "worker:observe-source": "node --import tsx backend/src/workers/observe-source/main.ts",
    "worker:periodic-crawl": "node --import tsx backend/src/workers/periodic-crawl/main.ts",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "test:e2e": "sh test/scripts/run-e2e.sh",
    "test:e2e:cases": "playwright test --config test/playwright.config.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit -p frontend/tsconfig.json",
    "precommit": "npm run format && npm run lint -- --fix && npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "pg-mem": "^3.0.14",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "fast-xml-parser": "^5.7.2",
    "hono": "^4.12.15",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "pg-boss": "^12.18.1",
    "pino": "^10.3.1",
    "uuid": "^14.0.0",
    "vue": "^3.5.33"
  }
}
