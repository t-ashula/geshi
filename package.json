{
  "name": "geshi",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "backend:dev": "node --watch --import tsx backend/src/index.ts",
    "backend:start": "node --import tsx backend/src/index.ts",
    "backend:worker:dev": "node --watch --import tsx backend/src/worker.ts",
    "backend:worker:start": "node --import tsx backend/src/worker.ts",
    "dbmate": "dbmate --migrations-dir backend/db/migrations --schema-file backend/db/schema.sql",
    "db:migrate:up": "npm run dbmate -- up",
    "db:migrate:down": "npm run dbmate -- down",
    "db:migrate:new": "npm run dbmate -- new",
    "db:migrate:status": "npm run dbmate -- status",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "build": "npm run typecheck && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "test": "npm run test:unit",
    "test:unit": "npm run test:unit:back && npm run test:unit:front",
    "test:unit:back": "vitest run backend/test/unit",
    "test:unit:front": "vitest run --passWithNoTests frontend/test/unit",
    "test:mid": "npm run test:mid:back && npm run test:mid:front",
    "test:mid:back": "vitest run --passWithNoTests backend/test/mid",
    "test:mid:front": "vitest run --passWithNoTests frontend/test/mid",
    "test:integration": "vitest run --passWithNoTests test/integration",
    "test:watch": "vitest --passWithNoTests backend/test/unit frontend/test/unit",
    "typecheck": "vue-tsc --noEmit -p frontend/tsconfig.json && tsc --noEmit -p backend/tsconfig.json && tsc --noEmit -p cli/tsconfig.json",
    "lint": "eslint frontend backend cli",
    "lint:fix": "npm run -s lint -- --fix"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/hono": "^6.20.6",
    "@hono/node-server": "^1.19.13",
    "bullmq": "^5.73.3",
    "hono": "^4.12.12",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "uuid": "^13.0.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "dbmate": "^2.32.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
