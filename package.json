{
  "name": "geshi",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "backend:dev": "node --watch --import tsx backend/src/index.ts",
    "backend:start": "node --import tsx backend/src/index.ts",
    "build": "npm run typecheck && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json && tsc --noEmit -p backend/tsconfig.json && tsc --noEmit -p cli/tsconfig.json",
    "lint": "eslint frontend backend cli"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "hono": "^4.9.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1"
  }
}
