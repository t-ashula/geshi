{
  "name": "geshi",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "bin": {
    "geshi": "./bin/geshi"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "tsx watch backend/src/index.ts",
    "backend:dev:start": "sh scripts/start-backend.sh",
    "backend:dev:stop": "sh scripts/stop-backend.sh",
    "backend:start": "node --import tsx backend/src/index.ts",
    "worker:start": "sh scripts/start-workers.sh",
    "worker:stop": "sh scripts/stop-workers.sh",
    "worker:acquire-content": "node --import tsx backend/src/workers/acquire-content/main.ts",
    "worker:observe-source": "node --import tsx backend/src/workers/observe-source/main.ts",
    "worker:periodic-crawl": "node --import tsx backend/src/workers/periodic-crawl/main.ts",
    "worker:record-content": "node --import tsx backend/src/workers/record-content/main.ts",
    "worker:recording-scheduler": "node --import tsx backend/src/workers/recording-scheduler/main.ts",
    "worker:transcript-chunk": "node --import tsx backend/src/workers/transcript-chunk/main.ts",
    "worker:transcript-split": "node --import tsx backend/src/workers/transcript-split/main.ts",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "frontend:dev:start": "sh scripts/start-frontend.sh",
    "frontend:dev:stop": "sh scripts/stop-frontend.sh",
    "test:e2e": "sh test/scripts/run-e2e.sh basic",
    "test:e2e:recording": "sh test/scripts/run-e2e.sh recording",
    "test:e2e:transcript": "sh test/scripts/run-e2e.sh transcript",
    "test:e2e:cases": "playwright test --config test/playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/geshi-sdk/tsconfig.json && tsc --noEmit -p packages/geshi-plugin-go-jp-rss/tsconfig.json && tsc --noEmit -p packages/geshi-plugin-sample-streaming/tsconfig.json && vue-tsc --noEmit -p frontend/tsconfig.json",
    "precommit": "npm run format && npm run lint -- --fix && npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.9"
  },
  "dependencies": {
    "@geshi/plugin-go-jp-rss": "file:packages/geshi-plugin-go-jp-rss",
    "@geshi/plugin-sample-streaming": "file:packages/geshi-plugin-sample-streaming",
    "@geshi/sdk": "file:packages/geshi-sdk",
    "@hono/node-server": "^2.0.2",
    "fast-xml-parser": "^5.7.3",
    "hono": "^4.12.19",
    "kysely": "^0.29.0",
    "parse5": "^8.0.1",
    "pg": "^8.20.0",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "uuid": "^14.0.0",
    "vue": "^3.5.34"
  }
}
